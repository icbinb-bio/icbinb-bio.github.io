---
import type { Person } from '../data/workshop';

interface Props {
  people: readonly Person[];
  kind: 'speaker' | 'organizer';
}

const { people, kind } = Astro.props;
---

<div class:list={['profile-grid', `profile-grid-${kind}`]}>
  {people.map((person) => (
    <article class="profile">
      {person.photo ? (
        <img class="profile-mark profile-photo" src={person.photo} alt="" loading="lazy" width="160" height="160" />
      ) : (
        <div class="profile-mark" aria-hidden="true">{person.initials}</div>
      )}
      <div class="profile-copy">
        <h2>{person.name}</h2>
        <p class="profile-affiliation">{person.affiliation}</p>
        <p class="profile-focus">{person.focus}</p>
        <p class="profile-links">
          {person.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label}<span class="visually-hidden"> for {person.name} (external)</span>
            </a>
          ))}
        </p>
      </div>
    </article>
  ))}
</div>
