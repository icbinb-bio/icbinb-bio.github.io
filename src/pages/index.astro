---
import DateGrid from '../components/DateGrid.astro';
import Section from '../components/Section.astro';
import TopicGrid from '../components/TopicGrid.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { workshop } from '../data/workshop';

const [headlinePrefix, headlineSuffix] = workshop.name.split(': ');
const [taglinePrefix, taglineSuffix] = workshop.tagline.split('~');
const cleanTagline = workshop.tagline.replaceAll('~', '');
---

<SiteLayout title={`${workshop.shortName} | NeurIPS 2026`} description={cleanTagline}>
  <div class="home-hero">
    <img
      class="hero-banner"
      src="/images/icbinb-banner.jpg"
      alt="I Can't Believe It's Not Better waveform banner"
      width="1280"
      height="364"
    />
  </div>

  <div class="hero-copy-band">
    <div class="hero-copy">
      <h1>{headlinePrefix}:<br />{headlineSuffix}</h1>
      <p class="eyebrow hero-event">{workshop.eventLine}</p>
      <p class="tagline">{taglinePrefix}<br />{taglineSuffix}</p>
    </div>
  </div>

  <Section labelledby="key-dates">
    <div class="section-heading centered">
      <h2 id="key-dates">Key Dates</h2>
      <p>All deadlines are 11:59 p.m. Anywhere on Earth and remain subject to final confirmation.</p>
    </div>
    <DateGrid />
  </Section>

  <Section surface="warm" narrow labelledby="why">
    <div class="section-heading">
      <h2 id="why">Benchmarks are only the beginning.</h2>
    </div>
    <div class="prose">
      <p>
        AI is reshaping genomics, cellular modeling, structural biology, and therapeutic discovery.
        Yet strong benchmark results often fail to survive new mutations, perturbations, individuals,
        assays, or deployment settings.
      </p>
      <p>
        This full-day workshop brings machine learning and life science researchers together to study
        those failures directly: what breaks, why it breaks, how we should evaluate it, and what more
        reliable scientific systems require.
      </p>
    </div>
  </Section>

  <Section narrow labelledby="topics">
    <div class="section-heading">
      <h2 id="topics">Topics</h2>
    </div>
    <TopicGrid />
  </Section>

  <Section surface="warm" narrow labelledby="initiative">
    <div class="section-heading">
      <h2 id="initiative">I Can't Believe It's Not Better Initiative</h2>
    </div>
    <div class="prose">
      <p>
        This workshop forms one workshop in a series as part of the larger I Can't Believe It's Not
        Better (ICBINB) activities. ICBINB-BIO is the official biology branch of the broader ICBINB
        initiative, which shares a commitment to candid failure
        analysis, negative results, unexpectedly strong simple baselines, and benchmarks that support
        the claims made from them.
      </p>
      <p>
        <a class="text-cta" href="/submit/">Read the call for papers <span aria-hidden="true">→</span></a>
      </p>
    </div>
  </Section>
</SiteLayout>
