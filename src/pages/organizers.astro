---
import PageIntro from '../components/PageIntro.astro';
import ProfileGrid from '../components/ProfileGrid.astro';
import Section from '../components/Section.astro';
import { workshop } from '../data/workshop';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Organizers | ICBINB-BIO 2026" description="Organizing committee for ICBINB-BIO at NeurIPS 2026.">
  <PageIntro
    eyebrow="Organizing committee"
    title="Organizers"
    lead="Researchers across machine learning, genomics, single-cell biology, and explainable clinical AI."
  />
  <Section>
    <ProfileGrid people={workshop.organizers} kind="organizer" />
    <div class="organizer-acknowledgement">
      <h2>Acknowledgement</h2>
      <p>ICBINB-BIO is independently organized by the committee listed above.</p>
      <p>We warmly thank the ICBINB team for welcoming us into the ICBINB community and supporting this workshop.</p>
    </div>
  </Section>
</SiteLayout>
