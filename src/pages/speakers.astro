---
import Notice from '../components/Notice.astro';
import PageIntro from '../components/PageIntro.astro';
import ProfileGrid from '../components/ProfileGrid.astro';
import Section from '../components/Section.astro';
import { workshop } from '../data/workshop';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Speakers | ICBINB-BIO 2026" description="Confirmed invited speakers for ICBINB-BIO at NeurIPS 2026.">
  <PageIntro
    eyebrow="Invited program"
    title="Speakers"
    lead="Five perspectives spanning genomics, health, pathology, biomedicine, and protein evolution."
  />
  <Section>
    <Notice label="Speaker list in progress">
      We are finalizing the speaker lineup and will release it here once confirmed.
    </Notice>
    <ProfileGrid people={workshop.speakers} kind="speaker" />
  </Section>
</SiteLayout>
